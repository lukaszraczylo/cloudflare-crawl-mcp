    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.25.0",
    "eslint-formatter-compact": "^9.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.26.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
