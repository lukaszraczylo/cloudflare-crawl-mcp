{
  "name": "@lukaszraczylo/cloudflare-crawl-mcp",
  "version": "1.0.0",
  "description": "MCP server for Cloudflare Browser Rendering Crawl API",
  "author": "Lukasz Raczylo <hello@raczylo.com> (https://raczylo.com)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
